# ═══════════════════════════════════════════════════════════════════
#  ALPHA MODULE — Environment Variables
#  Copy to .env and fill in values before running.
#  See README.md for full variable descriptions.
# ═══════════════════════════════════════════════════════════════════

# ── Mode ─────────────────────────────────────────────────────────
# true = paper trading (simulated fills, no real orders)
# false = live trading on Bybit (requires API keys below)
ALPHA_PAPER_MODE=true

# ── Server ────────────────────────────────────────────────────────
ALPHA_PORT=5001

# ── Security ──────────────────────────────────────────────────────
# Required. Guards POST /api/alpha/close and /close-all endpoints.
# Generate with: openssl rand -hex 32
ALPHA_INTERNAL_KEY=

# ── Exchange: Bybit (live trading only) ───────────────────────────
# Leave blank for paper mode. Only set when ALPHA_PAPER_MODE=false.
# Permissions required: Read + Trade (NO withdrawal permission)
# Recommended: use a Bybit sub-account dedicated to Alpha
ALPHA_BYBIT_API_KEY=
ALPHA_BYBIT_API_SECRET=

# ── Telegram Notifications ────────────────────────────────────────
# IMPORTANT: Create a NEW dedicated bot for Alpha via t.me/BotFather
# Do NOT reuse the main engine's TELEGRAM_BOT_TOKEN
# Setup:
#   1. Message @BotFather → /newbot → name it "Alpha Synaptic"
#   2. Copy the token below
#   3. Get your chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
ALPHA_TELEGRAM_BOT_TOKEN=
ALPHA_TELEGRAM_CHAT_ID=

# ── DO NOT SET THESE — they belong to the main engine only ────────
# BINANCE_API_KEY      ← main engine uses Binance, Alpha does NOT
# COINDCX_API_KEY      ← main engine uses CoinDCX, Alpha does NOT
# TELEGRAM_BOT_TOKEN   ← main engine's bot, Alpha has its own
