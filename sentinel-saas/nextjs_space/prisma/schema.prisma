generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  password        String
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  role            String           @default("user")
  referralCode    String?
  phone           String?
  accounts        Account[]
  bots            Bot[]
  exchangeApiKeys ExchangeApiKey[]
  sessions        Session[]
  subscription    Subscription?

  @@index([email])
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  tier              String    @default("free")
  coinScans         Int       @default(0)
  status            String    @default("trial")
  trialEndsAt       DateTime?
  currentPeriodEnd  DateTime?
  razorpayPaymentId String?
  razorpayOrderId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ExchangeApiKey {
  id           String   @id @default(cuid())
  userId       String
  exchange     String
  apiKey       String
  apiSecret    String
  encryptionIv String?
  label        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exchange])
  @@index([userId])
}

model Bot {
  id        String       @id @default(cuid())
  userId    String
  name      String
  exchange  String
  status    String       @default("stopped")
  isActive  Boolean      @default(false)
  startedAt DateTime?
  stoppedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  config    BotConfig?
  sessions  BotSession[]
  state     BotState?
  trades    Trade[]

  @@index([userId])
  @@index([status])
}

model BotConfig {
  id                 String   @id @default(cuid())
  botId              String   @unique
  mode               String   @default("paper")
  capitalPerTrade    Float    @default(100)
  maxOpenTrades      Int      @default(5)
  slMultiplier       Float    @default(0.8)
  tpMultiplier       Float    @default(1.0)
  maxLossPct         Float    @default(-15)
  multiTargetEnabled Boolean  @default(true)
  t1Multiplier       Float    @default(0.5)
  t2Multiplier       Float    @default(1.0)
  t3Multiplier       Float    @default(1.5)
  t1BookPct          Float    @default(0.25)
  t2BookPct          Float    @default(0.50)
  coinList           Json     @default("[]")
  leverageTiers      Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  brainType          String   @default("adaptive")
  segment            String   @default("ALL")
  bot                Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model BotState {
  id              String    @id @default(cuid())
  botId           String    @unique
  engineStatus    String    @default("idle")
  lastCycleAt     DateTime?
  cycleCount      Int       @default(0)
  cycleDurationMs Int?
  coinStates      Json?
  errorMessage    String?
  errorAt         DateTime?
  updatedAt       DateTime  @updatedAt
  bot             Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model Trade {
  id                      String           @id @default(cuid())
  botId                   String
  coin                    String
  position                String
  regime                  String
  confidence              Float
  mode                    String           @default("paper")
  leverage                Float
  capital                 Float
  quantity                Float            @default(0)
  entryPrice              Float
  currentPrice            Float?
  exitPrice               Float?
  stopLoss                Float
  takeProfit              Float
  slType                  String           @default("fixed")
  t1Price                 Float?
  t2Price                 Float?
  t3Price                 Float?
  t1Hit                   Boolean          @default(false)
  t2Hit                   Boolean          @default(false)
  trailingSl              Float?
  trailingTp              Float?
  trailingActive          Boolean          @default(false)
  trailSlCount            Int              @default(0)
  steppedLockLevel        Int              @default(-1)
  // Exit guard state — stamped every heartbeat by tradebook.update_unrealized()
  exitGuardActive         Boolean          @default(true)   // matches should_auto_close in engine
  exitCheckAt             DateTime?                          // UTC timestamp of last exit check run
  exitCheckPrice          Float?                             // price used in that exit check
  capitalProtectionActive Boolean          @default(false)
  originalQty             Float?
  originalCapital         Float?
  status                  String           @default("active")
  activePnl               Float            @default(0)
  activePnlPercent        Float            @default(0)
  totalPnl                Float            @default(0)
  totalPnlPercent         Float            @default(0)
  exitReason              String?
  exitPercent             Float?
  exchangeOrderId         String?
  exchangePositionId      String?
  sessionId               String?
  entryTime               DateTime         @default(now())
  exitTime                DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  partialBookings         PartialBooking[]
  bot                     Bot              @relation(fields: [botId], references: [id], onDelete: Cascade)
  session                 BotSession?      @relation(fields: [sessionId], references: [id])

  @@index([botId])
  @@index([status])
  @@index([coin])
  @@index([mode])
  @@index([sessionId])
  @@index([entryTime])
}

model BotSession {
  id           String    @id @default(cuid())
  botId        String
  sessionIndex Int       @default(1)
  startedAt    DateTime
  endedAt      DateTime?
  status       String    @default("active")
  mode         String    @default("paper")
  totalTrades  Int       @default(0)
  closedTrades Int       @default(0)
  winTrades    Int       @default(0)
  totalPnl     Float     @default(0)
  roi          Float     @default(0)
  winRate      Float     @default(0)
  maxDrawdown  Float     @default(0)
  bestTrade    Float     @default(0)
  worstTrade   Float     @default(0)
  totalCapital Float     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bot          Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  trades       Trade[]

  @@index([botId])
  @@index([status])
}

model PartialBooking {
  id          String   @id @default(cuid())
  tradeId     String
  target      String
  bookPercent Float
  quantity    Float
  exitPrice   Float
  pnl         Float
  pnlPercent  Float
  createdAt   DateTime @default(now())
  trade       Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
}

model CycleSnapshot {
  id             String                @id @default(cuid())
  cycleNumber    Int
  mode           String                @default("paper")
  engineBotId    String?
  scannedAt      DateTime
  durationMs     Int?
  btcRegime      String?
  btcConfidence  Float?
  btcPrice       Float?
  macroAction    String?
  coinsScanned   Int                   @default(0)
  eligibleCount  Int                   @default(0)
  deployedCount  Int                   @default(0)
  filteredCount  Int                   @default(0)
  createdAt      DateTime              @default(now())
  coinResults    CoinScanResult[]
  heatmapEntries SegmentHeatmapEntry[]

  @@index([scannedAt])
  @@index([cycleNumber])
  @@index([mode])
}

model CoinScanResult {
  id             String        @id @default(cuid())
  cycleId        String
  symbol         String
  regime         String?
  regimeFull     String?
  action         String?
  side           String?
  confidence     Float?
  conviction     Float?
  tfAgreement    Int?
  atr            Float?
  price          Float?
  deployStatus   String?
  wasDeployed    Boolean       @default(false)
  athenaDecision String?
  createdAt      DateTime      @default(now())
  cycle          CycleSnapshot @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId])
  @@index([symbol])
  @@index([action])
  @@index([createdAt])
}

model SegmentHeatmapEntry {
  id             String        @id @default(cuid())
  cycleId        String
  segment        String
  compositeScore Float?
  vwRr           Float?
  btcAlpha       Float?
  breadthPct     Float?
  isSelected     Boolean       @default(false)
  rank           Int?
  createdAt      DateTime      @default(now())
  cycle          CycleSnapshot @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId])
  @@index([segment])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  actor     String
  actorRole String   @default("system")
  action    String
  category  String   @default("system")
  details   String
  ipAddress String?
  severity  String   @default("info")
  createdAt DateTime @default(now())

  @@index([category])
  @@index([severity])
  @@index([timestamp])
}

model AthenaDecisionLog {
  id            String    @id @default(cuid())

  // ── When & Where ──
  timestamp     DateTime  @default(now())
  cycle         Int

  // ── Coin Context ──
  symbol        String
  segment       String?
  regime        String?
  conviction    Float?

  // ── Athena Decision ──
  action        String                         // EXECUTE, VETO, REDUCE_SIZE, SKIP
  side          String?                        // LONG / SHORT (athena_direction)
  confidence    Float?                         // Athena 0.0–1.0 confidence
  reasoning     String?
  riskFlags     String?                        // JSON array
  model         String?
  latencyMs     Int?
  suggestedSl   Float?
  suggestedTp   Float?
  entryPrice    Float?

  // ── Deployment Outcome ──
  deployed      Boolean   @default(false)
  deployReason  String?

  // ── Trade Outcome (backfilled on close) ──
  tradeId       String?                        // soft FK to Trade
  pnl           Float?
  pnlPct        Float?
  exitPrice     Float?
  tradeStatus   String?                        // ACTIVE / CLOSED
  closedAt      DateTime?

  createdAt     DateTime  @default(now())

  @@index([symbol])
  @@index([timestamp])
  @@index([action])
  @@index([cycle])
  @@index([tradeId])
  @@index([deployed])
}

// ─── Trade Journal: Reconciliation Log ────────────────────────────────────────
// Stores engine-vs-exchange health check results for the Live Journal tab.
// Written by /api/journal/health — read-only by all other routes.
model ReconciliationLog {
  id            String   @id @default(cuid())
  userId        String
  botId         String?
  checkType     String   // "trade_count" | "balance_match" | "duplicate_order"
  status        String   // "pass" | "fail" | "warning"
  engineCount   Int?
  exchangeCount Int?
  delta         Float?
  notes         String?
  checkedAt     DateTime @default(now())

  @@index([userId])
  @@index([checkedAt])
  @@index([status])
}
